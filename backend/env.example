# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME=DevEduHub
APP_ENV=local
APP_KEY=                          # Generate: php artisan key:generate
APP_DEBUG=true
APP_URL=http://localhost:8080
APP_PORT=8080                     # Host port for Nginx

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
DB_CONNECTION=pgsql
DB_HOST=db                        # Docker service name
DB_PORT=5432
DB_PORT_EXTERNAL=5432             # Host port exposed for external tools
DB_DATABASE=deveduhub
DB_USERNAME=postgres
DB_PASSWORD=secret                # Change in production!

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=redis                  # Docker service name
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_PORT_EXTERNAL=6379
REDIS_QUEUE_CONNECTION=default
REDIS_QUEUE=default
REDIS_QUEUE_RETRY_AFTER=200

# ── Queue ─────────────────────────────────────────────────────────────────────
QUEUE_CONNECTION=redis

# ── Python Grader Service ─────────────────────────────────────────────────────
GRADER_URL=http://grader:8000     # Docker service name
GRADER_PORT=8000                  # Host port exposed externally
GRADER_TIMEOUT=150
GRADER_CONNECT_TIMEOUT=10
GRADER_QUEUE=grading

# ── Mail ──────────────────────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=mailpit                 # Docker service name (dev only)
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=noreply@deveduhub.com
MAIL_FROM_NAME=DevEduHub

# ── Sanctum ───────────────────────────────────────────────────────────────────
SANCTUM_STATEFUL_DOMAINS=localhost:8080,localhost:3000

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_LEVEL=debug
