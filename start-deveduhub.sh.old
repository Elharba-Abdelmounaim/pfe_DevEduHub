#!/bin/bash

# DevEduHub - Complete Management Script
# Usage: ./start-deveduhub.sh [start|stop|restart|status|logs|shell|migrate|rebuild]

set -e

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m'

# Paths
PROJECT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
BACKEND_DIR="$PROJECT_DIR/backend"
FRONTEND_DIR="$PROJECT_DIR/frontend"

# Functions
print_header() {
    echo -e "${CYAN}"
    echo "╔════════════════════════════════════════════════════════════╗"
    echo "║           🎓 DevEduHub Management Script                   ║"
    echo "╚════════════════════════════════════════════════════════════╝"
    echo -e "${NC}"
}

print_success() { echo -e "${GREEN}[✓]${NC} $1"; }
print_error() { echo -e "${RED}[✗]${NC} $1"; }
print_info() { echo -e "${BLUE}[ℹ]${NC} $1"; }
print_warning() { echo -e "${YELLOW}[!]${NC} $1"; }

check_docker() {
    if ! command -v docker &> /dev/null; then
        print_error "Docker is not installed!"
        exit 1
    fi
    if ! docker info &> /dev/null; then
        print_error "Docker is not running! Start it with: sudo systemctl start docker"
        exit 1
    fi
    print_success "Docker is running"
}

check_env() {
    if [ ! -f "$BACKEND_DIR/.env" ]; then
        print_warning ".env file not found, creating from example..."
        cp "$BACKEND_DIR/.env.example" "$BACKEND_DIR/.env" 2>/dev/null || touch "$BACKEND_DIR/.env"
        echo "DB_PASSWORD=postgres" >> "$BACKEND_DIR/.env"
        print_success ".env created"
    fi
    
    # Ensure DB_PASSWORD is postgres
    if ! grep -q "DB_PASSWORD=postgres" "$BACKEND_DIR/.env"; then
        print_warning "Fixing DB_PASSWORD in .env..."
        sed -i 's/DB_PASSWORD=.*/DB_PASSWORD=postgres/' "$BACKEND_DIR/.env"
    fi
}

wait_for_db() {
    print_info "Waiting for database to be ready..."
    local retries=30
    while [ $retries -gt 0 ]; do
        if docker exec deveduhub_db pg_isready -U postgres -d deveduhub &> /dev/null; then
            print_success "Database is ready"
            return 0
        fi
        sleep 2
        ((retries--))
        echo -n "."
    done
    print_error "Database failed to start"
    return 1
}

start_backend() {
    print_info "Starting Backend (Laravel + Docker)..."
    cd "$BACKEND_DIR"
    
    check_env
    
    # Check if already running
    if docker ps | grep -q "deveduhub_app"; then
        print_warning "Backend is already running!"
        return 0
    fi
    
    # Start services
    make up
    
    # Wait for DB
    wait_for_db
    
    # Run migrations
    print_info "Running migrations..."
    if docker exec deveduhub_app php artisan migrate:fresh --seed --force 2>/dev/null; then
        print_success "Migrations completed"
    else
        print_warning "Migration might have failed, but continuing..."
    fi
    
    print_success "Backend is running at http://localhost:8080"
}

start_frontend() {
    print_info "Starting Frontend (React + Vite)..."
    cd "$FRONTEND_DIR"
    
    # Check if already running
    if [ -f /tmp/deveduhub-frontend.pid ] && ps -p "$(cat /tmp/deveduhub-frontend.pid 2>/dev/null)" &> /dev/null; then
        print_warning "Frontend is already running!"
        return 0
    fi
    
    # Install dependencies if needed
    if [ ! -d "node_modules" ]; then
        print_warning "Installing npm dependencies..."
        npm install
    fi
    
    # Start dev server
    nohup npm run dev > /tmp/frontend.log 2>&1 &
    echo $! > /tmp/deveduhub-frontend.pid
    
    sleep 3
    print_success "Frontend is running at http://localhost:3000"
}

stop_backend() {
    print_info "Stopping Backend..."
    cd "$BACKEND_DIR"
    make down 2>/dev/null || docker compose down
    print_success "Backend stopped"
}

stop_frontend() {
    print_info "Stopping Frontend..."
    if [ -f /tmp/deveduhub-frontend.pid ]; then
        kill "$(cat /tmp/deveduhub-frontend.pid)" 2>/dev/null || true
        rm -f /tmp/deveduhub-frontend.pid
        print_success "Frontend stopped"
    else
        print_warning "Frontend was not running"
    fi
}

show_status() {
    echo -e "${CYAN}=== Docker Containers ===${NC}"
    docker ps --format "table {{.Names}}\t{{.Status}}\t{{.Ports}}" 2>/dev/null | grep deveduhub || echo "No containers running"
    
    echo ""
    echo -e "${CYAN}=== Frontend ===${NC}"
    if [ -f /tmp/deveduhub-frontend.pid ] && ps -p "$(cat /tmp/deveduhub-frontend.pid 2>/dev/null)" &> /dev/null; then
        print_success "Running (PID: $(cat /tmp/deveduhub-frontend.pid))"
    else
        print_error "Not running"
    fi
    
    echo ""
    echo -e "${CYAN}=== URLs ===${NC}"
    echo "  Frontend:  http://localhost:3000"
    echo "  Backend:   http://localhost:8080"
    echo "  Mailpit:   http://localhost:8025"
}

show_logs() {
    echo -e "${CYAN}Select logs to view:${NC}"
    echo "1) Laravel (app)"
    echo "2) Nginx"
    echo "3) Database"
    echo "4) Frontend"
    echo "5) All"
    read -rp "Choice [1-5]: " choice
    
    case $choice in
        1) cd "$BACKEND_DIR" && make logs ;;
        2) docker logs -f deveduhub_nginx ;;
        3) docker logs -f deveduhub_db ;;
        4) tail -f /tmp/frontend.log 2>/dev/null || print_error "Frontend not running" ;;
        5) 
            cd "$BACKEND_DIR" && make logs &
            tail -f /tmp/frontend.log 2>/dev/null &
            wait
            ;;
        *) print_error "Invalid choice" ;;
    esac
}

rebuild() {
    print_warning "This will rebuild all containers and DELETE database data!"
    read -rp "Are you sure? [y/N]: " confirm
    if [[ $confirm =~ ^[Yy]$ ]]; then
        stop_frontend
        cd "$BACKEND_DIR"
        make down
        docker volume rm backend_pg_data backend_laravel_storage 2>/dev/null || true
        docker rmi backend-app backend-worker backend-notifier backend-scheduler 2>/dev/null || true
        docker compose build --no-cache
        start_backend
        start_frontend
    fi
}

shell_access() {
    echo -e "${CYAN}Select shell:${NC}"
    echo "1) Laravel (app)"
    echo "2) Database (PostgreSQL)"
    echo "3) Redis"
    echo "4) Grader (Python)"
    read -rp "Choice [1-4]: " choice
    
    case $choice in
        1) docker exec -it deveduhub_app sh ;;
        2) docker exec -it deveduhub_db psql -U postgres -d deveduhub ;;
        3) docker exec -it deveduhub_redis redis-cli ;;
        4) docker exec -it deveduhub_grader sh ;;
        *) print_error "Invalid choice" ;;
    esac
}

run_migrations() {
    print_info "Running migrations..."
    docker exec deveduhub_app php artisan migrate --force
    print_success "Migrations completed"
}

# Show menu and handle choice
show_menu() {
    print_header
    echo "Select an option:"
    echo ""
    echo -e "${GREEN}1)${NC} Start All (Backend + Frontend)"
    echo -e "${GREEN}2)${NC} Stop All"
    echo -e "${GREEN}3)${NC} Restart All"
    echo -e "${GREEN}4)${NC} Status"
    echo -e "${GREEN}5)${NC} View Logs"
    echo -e "${GREEN}6)${NC} Shell Access"
    echo -e "${GREEN}7)${NC} Run Migrations Only"
    echo -e "${YELLOW}8)${NC} Rebuild Everything (⚠️ Destructive)"
    echo -e "${RED}0)${NC} Exit"
    echo ""
    read -rp "Enter choice [0-8]: " choice
    echo ""
}

# Handle menu choice
handle_menu() {
    case $1 in
        1) check_docker; start_backend; start_frontend; show_final_status ;;
        2) stop_frontend; stop_backend ;;
        3) stop_frontend; stop_backend; sleep 2; check_docker; start_backend; start_frontend; show_final_status ;;
        4) show_status ;;
        5) show_logs ;;
        6) shell_access ;;
        7) run_migrations ;;
        8) rebuild ;;
        0) echo "Goodbye!"; exit 0 ;;
        *) print_error "Invalid choice: $1" ;;
    esac
}

show_final_status() {
    echo ""
    print_success "🎉 DevEduHub is fully running!"
    echo ""
    echo "URLs:"
    echo "  Frontend:  http://localhost:3000"
    echo "  Backend:   http://localhost:8080"
    echo "  Mailpit:   http://localhost:8025"
    echo ""
    echo "Test Accounts:"
    echo "  teacher@deveduhub.com  / password"
    echo "  student1@deveduhub.com / password"
    echo "  student2@deveduhub.com / password"
}

# Main
case "${1:-}" in
    start)
        check_docker
        start_backend
        start_frontend
        show_final_status
        ;;
    
    stop)
        stop_frontend
        stop_backend
        print_success "All services stopped"
        ;;
    
    restart)
        $0 stop
        sleep 2
        $0 start
        ;;
    
    status)
        show_status
        ;;
    
    logs)
        show_logs
        ;;
    
    shell)
        shell_access
        ;;
    
    migrate)
        run_migrations
        ;;
    
    rebuild)
        rebuild
        ;;
    
    *)
        # Interactive menu
        show_menu
        handle_menu "$choice"
        ;;
esac